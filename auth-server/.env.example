# Port for the auth server
PORT=3000

# Optional: base URL of this auth server (used for OAuth callback). Default: http://localhost:PORT
# Only set if you use a different host (e.g. http://127.0.0.1:3000) so it matches Google Cloud.
# AUTH_SERVER_BASE=http://localhost:3000

# Full URL where your front end lives (user is redirected here after login)
# Examples:
#   Live Server / local: http://localhost:5501/html/front-pages/landing-page.html
#   Production:  https://yourdomain.com/html/front-pages/landing-page.html
FRONT_END_URL=http://localhost:5501/html/front-pages/landing-page.html

# Google OAuth (from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- PostgreSQL (for MapData, client uploads, processing requests) ----
# When set, the server uses PostgreSQL instead of SQLite/JSON for map data and admin data.
# Create database "Temadigital_Data_Portal" in pgAdmin, then run sql/Temadigital_Data_Portal_PostgreSQL.sql and sql/03-admin-tables-postgres.sql
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password
PG_DATABASE=Temadigital_Data_Portal

# Admin approval code: required when someone registers with "Sign up as: Admin".
# Set this to a secret string (e.g. a password only admins know). Registrants must enter this exact value to become admin.
# Example: ADMIN_REGISTRATION_CODE=my-secret-admin-code-2024
ADMIN_REGISTRATION_CODE=

# Directory for client-uploaded files (relative to auth-server or absolute path). Created automatically if missing.
UPLOAD_DIR=uploads

# ---- SFTP Server Settings (Local Dev) ----
SFTP_PORT=2222
SFTP_USER=admin
SFTP_PASS=admin123
